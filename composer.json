{
    "name": "psc-acme/middleware-order",
    "description": "Package middleware-order for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\MiddlewareOrder\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "psr/event-dispatcher": "^1.0",
        "league/commonmark": "^2.0",
        "symfony/validator": "^7.0",
        "symfony/event-dispatcher": "^7.0",
        "symfony/uid": "^7.0"
    },
    "require-dev": {
        "phpstan/phpstan-symfony": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}